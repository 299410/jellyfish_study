generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model QuestionSet {
  id        String     @id @default(uuid())
  name      String
  questions Question[]
  sessions  Session[]
  createdAt DateTime   @default(now())
}

model Question {
  id        String      @id @default(uuid())
  content   String      
  order     Int         
  setId     String
  set       QuestionSet @relation(fields: [setId], references: [id], onDelete: Cascade)
}

model Session {
  id              String          @id @default(uuid())
  questionSetId   String?         
  questionSetName String          
  date            DateTime        @default(now())
  results         SessionResult[]
  set             QuestionSet?    @relation(fields: [questionSetId], references: [id], onDelete: SetNull)
}

model SessionResult {
  id         String  @id @default(uuid())
  sessionId  String
  session    Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question   String  
  userAnswer String  
  feedback   String  
}

model User {
  id            String         @id @default(uuid())
  name          String
  decks         Deck[]
  studySessions StudySession[]
  createdAt     DateTime       @default(now())
}

model Deck {
  id                String         @id @default(uuid())
  userId            String
  name              String
  description       String?
  maxNewCardsPerDay Int            @default(20)
  maxReviewsPerDay  Int            @default(200)
  cards             Flashcard[]
  studySessions     StudySession[]
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime       @default(now())
}

model Flashcard {
  id                String             @id @default(uuid())
  deckId            String
  front             String    
  back              String    
  deck              Deck               @relation(fields: [deckId], references: [id], onDelete: Cascade)
  studySessionCards StudySessionCard[]
  
  status         String    @default("NEW")
  stepIndex      Int       @default(0)
  interval       Int       @default(0)     
  repetition     Int       @default(0)     
  easinessFactor Float     @default(2.5)   
  nextReviewDate DateTime  @default(now()) 
  
  createdAt      DateTime  @default(now())
}

model CardReviewLog {
  id         String   @id @default(uuid())
  cardId     String
  deckId     String
  status     String   // NEW | LEARNING | REVIEW | RELEARNING
  action     String   // again | hard | good | easy
  createdAt  DateTime @default(now())

  @@index([deckId, createdAt])
}

model ActivityLog {
  id        String   @id @default(uuid())
  userId    String
  activity  String   // FLASHCARD | FREE_CHAT | INTERVIEW
  duration  Int      // Active duration in seconds
  createdAt DateTime @default(now())
  
  @@index([userId, createdAt])
}

model StudySession {
  id            String             @id @default(uuid())
  userId        String
  deckId        String
  currentIndex  Int                @default(0)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  cards         StudySessionCard[]

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deck          Deck               @relation(fields: [deckId], references: [id], onDelete: Cascade)

  @@unique([userId, deckId])
}

model StudySessionCard {
  id             String       @id @default(uuid())
  sessionId      String
  cardId         String
  dueAt          DateTime?    // NULL = Active in Queue; NOT NULL = In Waiting Pool (waiting for timestamp)
  orderIndex     Int

  session        StudySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  card           Flashcard    @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([sessionId, orderIndex])
}

